VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Workspace setup restrictions (optional but recommended)
# Comma-separated email domains allowed to create workspaces (e.g. acme.com,partner.com)
VITE_SETUP_ALLOWED_DOMAINS=
# Comma-separated exact emails allowed to create workspaces (for cross-domain exceptions)
VITE_SETUP_ALLOWED_EMAILS=
# Leave both empty to allow anyone to create a workspace (not recommended for production)

# Integration 1 — OneDrive Order Config XLSX sync
VITE_ONEDRIVE_CLIENT_ID=
VITE_ONEDRIVE_TENANT_ID=
VITE_ONEDRIVE_FILE_ITEM_ID=

# Integration 2 — monday.com Location List sync
VITE_MONDAY_API_KEY=
VITE_MONDAY_BOARD_ID=

# Integration 3 — Droptop Month End API pull
VITE_DROPTOP_API_KEY=
VITE_DROPTOP_BASE_URL=https://droptop-app.com
